<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="tattva_image_editor_project" resource="default" engine="innodb" comment="Tattva Image Editor Project">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="Project ID"/>
        <column xsi:type="varchar" name="uuid" nullable="false" length="64" comment="Project UUID"/>
        <column xsi:type="int" name="customer_id" padding="10" unsigned="true" nullable="false" identity="false" comment="Customer ID"/>
        <column xsi:type="smallint" name="store_id" padding="5" unsigned="true" nullable="false" identity="false" comment="Store ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Project Name"/>
        <column xsi:type="text" name="description" nullable="true" comment="Project Description"/>
        <column xsi:type="varchar" name="size" nullable="false" length="255" comment="Project Size"/>
        <column xsi:type="int" name="width" padding="10" unsigned="true" nullable="false" identity="false" comment="Project Width"/>
        <column xsi:type="int" name="height" padding="10" unsigned="true" nullable="false" identity="false" comment="Project Height"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" comment="Project Status"/>
        <column xsi:type="mediumtext" name="canvas_object" nullable="true" comment="Canvas Object JSON"/>
        <column xsi:type="varchar" name="thumbnail" nullable="true" length="255" comment="Thumbnail Image Path"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="TATTVA_IMAGE_EDITOR_PROJECT_UUID">
            <column name="uuid"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="TATTVA_IMG_ED_PROJECT_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
            table="tattva_image_editor_project" column="customer_id"
            referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="TATTVA_IMG_ED_PROJECT_STORE_ID_STORE_STORE_ID"
            table="tattva_image_editor_project" column="store_id"
            referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="TATTVA_IMAGE_EDITOR_PROJECT_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="TATTVA_IMAGE_EDITOR_PROJECT_STORE_ID" indexType="btree">
            <column name="store_id"/>
        </index>
        <index referenceId="TATTVA_IMAGE_EDITOR_PROJECT_STATUS" indexType="btree">
            <column name="status"/>
        </index>
    </table>

    <table name="tattva_image_editor_project_image" resource="default" engine="innodb" comment="Tattva Image Editor Project Image">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="Project Image ID"/>
        <column xsi:type="varchar" name="uuid" nullable="false" length="64" comment="Project Image UUID"/>
        <column xsi:type="int" name="project_id" padding="10" unsigned="true" nullable="false" identity="false" comment="Project ID"/>
        <column xsi:type="int" name="customer_id" padding="10" unsigned="true" nullable="false" identity="false" comment="Customer ID"/>
        <column xsi:type="smallint" name="store_id" padding="5" unsigned="true" nullable="false" identity="false" comment="Store ID"/>
        <column xsi:type="varchar" name="type" nullable="false" length="32" comment="Image Type"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" comment="Image Status"/>
        <column xsi:type="varchar" name="file_name" nullable="false" length="255" comment="Stored File Name"/>
        <column xsi:type="varchar" name="original_name" nullable="false" length="255" comment="Original File Name"/>
        <column xsi:type="text" name="file_path" nullable="false" comment="Relative File Path"/>
        <column xsi:type="varchar" name="mime_type" nullable="false" length="100" comment="Mime Type"/>
        <column xsi:type="varchar" name="extension" nullable="false" length="20" comment="File Extension"/>
        <column xsi:type="bigint" name="size_bytes" padding="20" unsigned="true" nullable="false" identity="false" comment="File Size Bytes"/>
        <column xsi:type="int" name="width" padding="10" unsigned="true" nullable="true" identity="false" comment="Image Width"/>
        <column xsi:type="int" name="height" padding="10" unsigned="true" nullable="true" identity="false" comment="Image Height"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="TATTVA_IMAGE_EDITOR_PROJECT_IMAGE_UUID">
            <column name="uuid"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="TATTVA_IMG_ED_PRJ_IMG_PROJECT_ID_TATTVA_IMG_ED_PRJ_ID"
            table="tattva_image_editor_project_image" column="project_id"
            referenceTable="tattva_image_editor_project" referenceColumn="id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="TATTVA_IMG_ED_PRJ_IMG_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
            table="tattva_image_editor_project_image" column="customer_id"
            referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="TATTVA_IMG_ED_PRJ_IMG_STORE_ID_STORE_STORE_ID"
            table="tattva_image_editor_project_image" column="store_id"
            referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="TATTVA_IMAGE_EDITOR_PROJECT_IMAGE_PROJECT_ID" indexType="btree">
            <column name="project_id"/>
        </index>
        <index referenceId="TATTVA_IMAGE_EDITOR_PROJECT_IMAGE_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="TATTVA_IMAGE_EDITOR_PROJECT_IMAGE_STORE_ID" indexType="btree">
            <column name="store_id"/>
        </index>
        <index referenceId="TATTVA_IMAGE_EDITOR_PROJECT_IMAGE_STATUS" indexType="btree">
            <column name="status"/>
        </index>
    </table>
</schema>
