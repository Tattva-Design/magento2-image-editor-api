scalar Json @implementation(class: "TattvaDesign\\ImageEditorApi\\Model\\GraphQl\\Type\\Scalar\\JsonScalar")

type Query {
    imageEditorProjects(
        status: String = "active" @doc(description: "Filter projects by status (defaults to active).")
        pageSize: Int = 20 @doc(description: "How many items should be returned per page.")
        currentPage: Int = 1 @doc(description: "The current results page, starting from 1.")
    ): ImageEditorProjectListResult!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\Projects")
    @doc(description: "Returns the current customer's image editor projects ordered by newest created first.")
    imageEditorProjectByUuid(
        uuid: String! @doc(description: "The project UUID.")
    ): ImageEditorProject!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\ProjectByUuid")
    @doc(description: "Returns a single project by its UUID for the current customer.")
    imageEditorProjectImages(
        projectUuid: String! @doc(description: "The project UUID.")
        pageSize: Int = 20 @doc(description: "How many items should be returned per page.")
        currentPage: Int = 1 @doc(description: "The current results page, starting from 1.")
        sort: ImageEditorProjectImageSortInput @doc(description: "Optional sort configuration.")
    ): ImageEditorProjectImageListResult!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\ProjectImages")
    @doc(description: "Returns the current customer's project images for the current store.")
    imageEditorDefaultImages(
        search: String @doc(description: "Search keyword(s) to filter by description.")
        pageSize: Int = 20 @doc(description: "How many items should be returned per page.")
        currentPage: Int = 1 @doc(description: "The current results page, starting from 1.")
    ): ImageEditorProjectImageListResult!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\DefaultImages")
    @doc(description: "Returns the global default system images.")
    imageEditorProject(
        uuid: String! @doc(description: "The project UUID.")
    ): ImageEditorProject!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\Project")
    @doc(description: "Returns the single project details by UUID.")
}

type Mutation {
    createImageEditorProject(
        input: CreateImageEditorProjectInput!
    ): ImageEditorProject!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\CreateProject")
    @doc(description: "Creates a new image editor project for the current customer in the current store.")
    updateImageEditorProject(
        input: UpdateImageEditorProjectInput!
    ): ImageEditorProject!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\UpdateProject")
    @doc(description: "Updates an existing image editor project for the current customer in the current store.")
    deleteImageEditorProject(
        uuid: String!
    ): DeleteImageEditorProjectResult!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\DeleteProject")
    @doc(description: "Deletes an existing image editor project for the current customer in the current store.")
    createImageEditorProjectImage(
        input: CreateImageEditorProjectImageInput!
    ): ImageEditorProjectImage!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\CreateProjectImage")
    @doc(description: "Uploads an image to an existing project for the current customer in the current store.")
    createImageEditorDefaultImage(
        input: CreateImageEditorDefaultImageInput!
    ): ImageEditorProjectImage!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\CreateDefaultImage")
    @doc(description: "Uploads a new global default system image.")
    deleteImageEditorProjectImage(
        imageUuid: String!
    ): DeleteImageEditorProjectImageResult!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\DeleteProjectImage")
    @doc(description: "Deletes an existing project image for the current customer in the current store.")
    updateImageEditorProjectThumbnail(
        input: UpdateImageEditorProjectThumbnailInput!
    ): ImageEditorProject!
    @resolver(class: "\\TattvaDesign\\ImageEditorApi\\Model\\Resolver\\UpdateProjectThumbnail")
    @doc(description: "Updates only the thumbnail of an existing project for the current customer in the current store.")
}

input CreateImageEditorProjectInput {
    name: String! @doc(description: "The project name.")
    description: String @doc(description: "The optional project description.")
    size: String! @doc(description: "The project size.")
    width: Int! @doc(description: "The project width.")
    height: Int! @doc(description: "The project height.")
    productSku: String @doc(description: "The associated product SKU.")
    frameType: String @doc(description: "The selected frame type.")
    paperType: String @doc(description: "The selected paper type.")
}

input UpdateImageEditorProjectInput {
    uuid: String! @doc(description: "The project UUID.")
    name: String @doc(description: "The project name.")
    description: String @doc(description: "The optional project description.")
    size: String @doc(description: "The project size.")
    width: Int @doc(description: "The optional project width.")
    height: Int @doc(description: "The optional project height.")
    canvasObject: Json @doc(description: "The canvas object JSON structure.")
    status: String @doc(description: "The project status.")
    productSku: String @doc(description: "The associated product SKU.")
    frameType: String @doc(description: "The selected frame type.")
    paperType: String @doc(description: "The selected paper type.")
}

scalar Upload @implementation(class: "TattvaDesign\\ImageEditorApi\\Model\\GraphQl\\UploadType") @doc(description: "The Upload scalar type represents file uploads.")

input CreateImageEditorProjectImageInput {
    projectUuid: String! @doc(description: "The project UUID.")
    file: Upload! @doc(description: "The uploaded file.")
}

input CreateImageEditorDefaultImageInput {
    file: Upload! @doc(description: "The uploaded file.")
    description: String @doc(description: "The description of the default image.")
}

input UpdateImageEditorProjectThumbnailInput {
    projectUuid: String! @doc(description: "The project UUID.")
    thumbnail: String @doc(description: "The base64-encoded thumbnail image or data URL.")
}

type ImageEditorProjectListResult {
    totalCount: Int! @doc(description: "The total number of matching projects.")
    items: [ImageEditorProject!]! @doc(description: "The current page of projects.")
    pageInfo: ImageEditorProjectPageInfo! @doc(description: "Pagination details for the current result set.")
}

input ImageEditorProjectImageSortInput {
    field: ImageEditorProjectImageSortField = CREATED_AT @doc(description: "The image field to sort by.")
    direction: ImageEditorSortDirection = DESC @doc(description: "The sort direction.")
}

enum ImageEditorProjectImageSortField {
    CREATED_AT
    NAME
}

enum ImageEditorSortDirection {
    ASC
    DESC
}

type ImageEditorProjectPageInfo {
    pageSize: Int! @doc(description: "How many items are returned per page.")
    currentPage: Int! @doc(description: "The current results page.")
    totalPages: Int! @doc(description: "The total number of available pages.")
    hasNextPage: Boolean! @doc(description: "Whether another page exists after the current page.")
    hasPreviousPage: Boolean! @doc(description: "Whether a page exists before the current page.")
}

type ImageEditorProjectImageListResult {
    totalCount: Int! @doc(description: "The total number of matching images.")
    items: [ImageEditorProjectImage!]! @doc(description: "The current page of images.")
    pageInfo: ImageEditorProjectPageInfo! @doc(description: "Pagination details for the current result set.")
}

type ImageEditorProject {
    id: Int! @doc(description: "The internal numeric project ID.")
    uuid: String! @doc(description: "The public project UUID.")
    customerId: Int! @doc(description: "The owning customer ID.")
    storeId: Int! @doc(description: "The owning store ID.")
    name: String! @doc(description: "The project name.")
    description: String @doc(description: "The project description.")
    size: String! @doc(description: "The project size.")
    width: Int! @doc(description: "The project width.")
    height: Int! @doc(description: "The project height.")
    status: String! @doc(description: "The project status.")
    productSku: String @doc(description: "The associated product SKU.")
    frameType: String @doc(description: "The selected frame type.")
    paperType: String @doc(description: "The selected paper type.")
    canvasObject: Json @doc(description: "The stored canvas object JSON structure.")
    thumbnailUrl: String @doc(description: "The project's thumbnail image URL.")
    createdAt: String! @doc(description: "The project creation timestamp.")
    updatedAt: String! @doc(description: "The project last update timestamp.")
}

type DeleteImageEditorProjectResult {
    uuid: String! @doc(description: "The deleted project UUID.")
    success: Boolean! @doc(description: "Whether the project was deleted successfully.")
}

type DeleteImageEditorProjectImageResult {
    imageUuid: String! @doc(description: "The deleted image UUID.")
    success: Boolean! @doc(description: "Whether the project image was deleted successfully.")
}

type ImageEditorProjectImage {
    id: Int! @doc(description: "The internal numeric project image ID.")
    uuid: String! @doc(description: "The public project image UUID.")
    projectId: Int! @doc(description: "The owning project ID.")
    customerId: Int! @doc(description: "The owning customer ID.")
    storeId: Int! @doc(description: "The owning store ID.")
    status: String! @doc(description: "The image status.")
    fileName: String! @doc(description: "The stored file name.")
    originalName: String! @doc(description: "The original uploaded file name.")
    filePath: String! @doc(description: "The relative media path.")
    imageUrl: String! @doc(description: "The browser-accessible media URL.")
    thumbnailUrl: String @doc(description: "The thumbnail URL of the uploaded image.")
    mimeType: String! @doc(description: "The detected mime type.")
    extension: String! @doc(description: "The stored file extension.")
    sizeBytes: Int! @doc(description: "The image file size in bytes.")
    width: Int @doc(description: "The image width in pixels.")
    height: Int @doc(description: "The image height in pixels.")
    description: String @doc(description: "The description of the image.")
    isDefault: Boolean! @doc(description: "Whether the image is a global default system image.")
    createdAt: String! @doc(description: "The image creation timestamp.")
    updatedAt: String! @doc(description: "The image last update timestamp.")
}

input CartItemInput {
    project_uuid: String @doc(description: "The UUID of the image editor project associated with this cart item.")
}
